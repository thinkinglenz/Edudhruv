# ════════════════════════════════════════════
# EduDhruv — Environment Variables
# Copy to .env.local and fill in values
# ════════════════════════════════════════════

# ── Supabase ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── Google Analytics (GA4) ──────────────────
# Get from: analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Google Search Console ───────────────────
# Get from: search.google.com/search-console → Settings → Ownership verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code

# ── Google AdSense ──────────────────────────
# Publisher ID (already known)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-8001713028154145
# Ad Slot IDs — get from AdSense → Ads → By ad unit
# Create 3 ad units: Leaderboard (728x90), Sidebar (300x250), In-feed (auto)
NEXT_PUBLIC_AD_SLOT_LEADERBOARD=1234567890
NEXT_PUBLIC_AD_SLOT_SIDEBAR=0987654321
NEXT_PUBLIC_AD_SLOT_INFEED=1122334455

# ── Amazon Associates ───────────────────────
# Associate ID (already known)
NEXT_PUBLIC_AMAZON_ASSOCIATE_ID=edudhruv-20

# ── Anthropic (Priya chatbot) ───────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Admin Panel ─────────────────────────────
# Simple password to protect /admin — change this!
ADMIN_PASSWORD=change_this_password_123

# ── Lead Notifications ──────────────────────
# Optional: email to notify when new lead comes in
LEAD_NOTIFY_EMAIL=edudruv@gmail.com

# ── Cloudflare Turnstile (Captcha — Free) ────
# Get keys from: https://dash.cloudflare.com → Turnstile → Add Site
# Domains to add: edudhruv.com, www.edudhruv.com, localhost (dev)
# Mode: Managed (recommended) — invisible most of the time
# Leave blank/placeholder → captcha is auto-skipped (dev mode)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
