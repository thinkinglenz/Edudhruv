# ─── Dependencies ──────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Testing & Coverage ────────────────────────────────
/coverage

# ─── Next.js ───────────────────────────────────────────
/.next/
/out/
*.tsbuildinfo
next-env.d.ts

# ─── Production builds ─────────────────────────────────
/build
/dist

# ─── Environment Variables (NEVER commit!) ─────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ─── Logs & Debug ──────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# ─── OS Files ──────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db

