.vscode/
.idea/
*.swp
*.swo

# ─── Vercel ────────────────────────────────────────────
.vercel

# ─── TypeScript ────────────────────────────────────────
*.tsbuildinfo

# ─── WordPress Backup (3GB — DO NOT COMMIT) ────────────
# Raw WP backup is migration source only — extracted data is in JSON
migration/wp-backup/
migration/*.tar.zst
migration/*.tar
migration/*.zip

# WP plugin backup tarballs accidentally copied via uploads/ — exclude
public/wp-content/uploads/backwpup/
public/wp-content/uploads/**/*.tar
public/wp-content/uploads/**/*.tar.gz
public/wp-content/uploads/**/*.zip
public/wp-content/uploads/**/*.bak.*
public/wp-content/uploads/**/*.sql

# ─── Migration outputs (kept in repo for re-import) ────
# These ARE committed so the data can be re-imported on Vercel:
#   - migration/wp_export.json
#   - migration/wp_pages.json
#   - migration/leads_export.json

# ─── Python venv ───────────────────────────────────────
automation/__pycache__/
automation/.env
automation/venv/
*.pyc

# ─── Local testing artifacts ───────────────────────────
/tmp
*.tmp
